{
  "name": "PlannerTool",
  "version": "1.0.0",
  "description": "Azure DevOps Planner UI and backend integration",
  "type": "module",
  "main": "planner.py",
  "scripts": {
    "test": "NODE_OPTIONS='--no-deprecation' NODE_ENV=production vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui --browser.enabled=true",
    "build": "vite build",
    "build:vendor": "rollup -c",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@open-wc/testing": "^4.0.0",
    "@playwright/test": "^1.42.0",
    "@rollup/plugin-node-resolve": "^13.3.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@vitest/browser": "^4.0.0",
    "@vitest/browser-playwright": "^4.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "chai": "^6.2.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-lit": "^2.2.1",
    "eslint-plugin-lit-a11y": "^5.1.1",
    "eslint-plugin-vitest": "^0.5.4",
    "jsdom": "^21.0.0",
    "playwright": "^1.50.0",
    "prettier": "^3.8.1",
    "rollup": "^2.79.1",
    "sinon": "^21.0.1",
    "sirv": "^2.0.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.0",
    "vitest-browser-lit": "^1.0.0"
  },
  "dependencies": {
    "lit": "^3.3.1"
  }
}
