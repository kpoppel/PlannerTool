{
  "root": true,
  "env": {
    "browser": true,
    "es2022": true,
    "node": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "extends": ["prettier", "eslint:recommended", "plugin:lit/recommended"],
  "plugins": ["lit"],
  "rules": {
    "no-var": "error",
    "prefer-const": "warn"
  },
  "overrides": [
    {
      "files": ["tests/**/*.js", "tests/**/*.mjs", "*.test.js"]
    }
  ],
  "ignorePatterns": ["dist/", "www/js/vendor/", "docs/"]
}
